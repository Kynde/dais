{;; Router: how an utterance is classified.
 ;;   :whole-match  command iff the WHOLE utterance matches (default)
 ;;   :prefix       commands must start with :prefix word; rest is dictation
 ;;   :key-armed    everything is dictation unless armed via `dais-ctl arm`
 :router {:strategy :whole-match
          :prefix "do"
          ;; Extra whole-utterance commands (merged over built-in defaults).
          ;; Entries map a phrase to either {:keys [...]} (key sequence) or
          ;; {:text "..." :submit true/false} (typed reply).
          :commands {}}

 ;; Dictation submit behavior: :no-enter | :enter-auto | :enter-always
 :enter-mode :no-enter

 ;; Target slots. :type :tmux needs :pane "session:window.pane";
 ;; :type :focus delivers to the focused app via ydotool.
 :targets {1 {:type :focus}
           2 {:type :tmux :pane "app:claude.0"}
           3 {:type :tmux :pane "system:claude.0"}}
 :active-slot 1

 :tmux ["tmux"]

 :focus {:ydotool ["/usr/bin/ydotool"]
         ;; nil -> $XDG_RUNTIME_DIR/.ydotool_socket (the client default)
         :ydotool-socket nil
         :key-delay-ms 2}

 :notifications {:enabled true :timeout-ms 2500}

 ;; Mic hygiene: force voice-off after a VAD session hears nothing for this
 ;; many minutes (decimals ok, nil/0 disables).
 :vad-idle-off-min 5

 ;; The resident ear worker (capture/VAD/ASR). :cmd is absolute so a
 ;; systemd/KDE-launched daemon needs no user PATH.
 :ear {:enabled? true
       :cmd ["/home/k/bin/pixi" "run" "-q" "ear"]
       :dir "ear"}
 ;; :source pins a PipeWire input node (`pactl list sources short`);
 ;; omit it to follow the system default source (headset plug/unplug works).
 :asr {:model "small.en" :device "cpu" :compute-type "int8" :language "en"}

 ;; VAD endpointing + false-trigger gates (JSON-serialized to the ear's
 ;; --tuning; underscore keys match the worker's DEFAULT_TUNING).
 :vad {"threshold" 0.5
       "release" 0.35
       "min_speech_ms" 300
       "silence_ms" 700
       "pre_roll_ms" 300
       "max_utterance_s" 30
       "no_speech_prob_max" 0.7
       "avg_logprob_min" -1.2}}
